# =============================================================================
# AI Customer Service Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/customer_service_ai
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM Settings & Priority ---
LLM_PRIORITY_LIST=["openai","google_genai","groq"]
EMBED_PRIORITY_LIST=["openai", "google_genai", "ollama"]
LLM_TIMEOUT_SECONDS=15.0

# --- LLM Credentials & Models ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GROQ_API_KEY=gsk_your-groq-api-key
GROQ_CHAT_MODEL=llama3-8b-8192

GOOGLEGENAI_API_KEY=AIzaSy_your-google-genai-key
GOOGLEGENAI_CHAT_MODEL=gemini-1.5-flash
GOOGLEGENAI_EMBEDDING_MODEL=text-embedding-004

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.1-8b-instruct

# --- Shopify Integration ---
SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_your-admin-api-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# --- Telegram Alerting ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Application ---
APP_ENV=development
DEBUG=true
